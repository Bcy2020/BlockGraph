{
  "id": "fixture-component-prop-trace",
  "module": "access-accuracy",
  "title": "Component Prop and Data Dependency Trace",
  "description": "Trace how data flows from API responses through service functions to component state and rendered output.",
  "repo": {
    "kind": "fixture",
    "path": "fixtures/ts-react-complex"
  },
  "task": {
    "type": "cross_module_flow_recovery",
    "prompt": "Trace the complete data flow for the Discussions feature: from the API response shape (Discussion type), through the service function that fetches it, to the component state that holds it, and the JSX that renders it. Include all intermediate files and function calls involved."
  },
  "allowed_conditions": [
    "no_graph",
    "code_facts_only",
    "block_graph",
    "block_graph_with_flows",
    "stale_or_incomplete_graph",
    "block_graph_mcp"
  ],
  "golden": {
    "expected_files": [
      {
        "id": "src/types/discussion.ts",
        "weight": 3,
        "required": true
      },
      {
        "id": "src/features/discussions/discussionService.ts",
        "weight": 3,
        "required": true
      },
      {
        "id": "src/features/discussions/DiscussionList.tsx",
        "weight": 3,
        "required": true
      },
      {
        "id": "src/lib/apiClient.ts",
        "weight": 2,
        "required": true
      }
    ],
    "expected_entities": [
      {
        "id": "src/types/discussion.ts#Discussion",
        "weight": 3,
        "required": true
      },
      {
        "id": "src/features/discussions/discussionService.ts#fetchDiscussions",
        "weight": 3,
        "required": true
      },
      {
        "id": "src/features/discussions/DiscussionList.tsx#DiscussionList",
        "weight": 3,
        "required": true
      },
      {
        "id": "src/lib/apiClient.ts#apiClient",
        "weight": 2,
        "required": true
      }
    ],
    "expected_blocks": [
      {
        "id": "Discussions",
        "weight": 3,
        "required": true
      },
      {
        "id": "Shared API Client",
        "weight": 2
      }
    ],
    "expected_flow_order": [
      "src/features/discussions/DiscussionList.tsx#DiscussionList",
      "src/features/discussions/discussionService.ts#fetchDiscussions",
      "src/lib/apiClient.ts#apiClient",
      "src/types/discussion.ts#Discussion"
    ],
    "must_not_include": {
      "files": [
        "src/features/auth/LoginForm.tsx",
        "src/features/comments/CommentForm.tsx",
        "src/features/teams/TeamList.tsx"
      ]
    }
  },
  "tags": [
    "data-flow",
    "type-propagation",
    "discussions"
  ]
}
